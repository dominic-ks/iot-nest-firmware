# Environment configuration for IoT Nest Firmware
# Copy this file to .env and fill in your specific values

# Node environment (development/production)
NODE_ENV=development

# Google Cloud IoT Core settings
# Replace with your GCP project ID
PROJECTID=your-gcp-project-id

# Cloud region for IoT Core
CLOUDREGION=your-cloud-region

# IoT Core registry ID
REGISTRYID=your-registry-id

# Device ID for this instance
DEVICEID=your-device-id

# MQTT broker settings (for Google IoT Core)
MQTTHOST=mqtt.googleapis.com
MQTTPORT=8883

# Path to private key file for authentication
PRIVATEKEYFILE=/path/to/your/rsa_private.pem

# Algorithm for JWT signing
ALGORHYTHM=RS256

# Message type for IoT Core
MESSAGETYPE=state

# Reverse SSH tunnel settings
# Hostname or IP address of the server accepting the reverse tunnel
REVERSE_SSH_HOST=example.com

# SSH port on the reverse tunnel server
REVERSE_SSH_PORT=22

# SSH user on the reverse tunnel server
REVERSE_SSH_USER=device-tunnel

# Port exposed on the reverse tunnel server for this device
REVERSE_SSH_REMOTE_PORT=2201

# Local SSH port on the device
REVERSE_SSH_LOCAL_PORT=22
